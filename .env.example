DATABASE_URL=postgres://corgitrack:corgitrack@localhost:5432/corgitrack
PUBLIC_BASE_URL=http://localhost:8000
APP_TIMEZONE=Europe/Astrakhan

# Bearer-токен для защищённого API (/api/v1/**). Обязательно смените на свой.
SERVICE_TOKEN=change-me

TELEGRAM_BOT_TOKEN=
# Кастомный Bot API server (прокси). Очистите значение для прямого доступа к Telegram.
TELEGRAM_API_SERVER_URL=https://tgproxy.advsrvone.pw/

# Эскалация напоминаний. Сначала уведомляется член семьи с наименьшим
# escalation_order. Если за ESCALATION_FIRST_DELAY_MINUTES никто не нажал
# «Принято» — повторный вопрос тому же человеку, далее каждые
# ESCALATION_STEP_MINUTES уведомляется следующий по списку; когда список
# исчерпан, доза помечается пропущенной.
ESCALATION_FIRST_DELAY_MINUTES=30
ESCALATION_STEP_MINUTES=5
REMINDER_LOOKAHEAD_MINUTES=30
SCHEDULER_TICK_SECONDS=60

RUST_LOG=info
